# Branch — environment variables (template).
# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER commit `.env` or paste real keys into source, chat, or screenshots.

# Generation provider for local dev. Default is the zero-cost `mock` adapter.
# Set to `flux-fal` to use real fal.ai generation (Milestone 3).
GENERATION_PROVIDER=mock

# Your fal.ai API key — used ONLY for your own local testing of the flux-fal
# adapter. The deployed app is BYOK (each user supplies their own key per
# request), so this key is never shipped to users or stored server-side.
# Get one at: https://fal.ai/dashboard/keys
FAL_KEY=

# Postgres connection (optional for local dev — the in-memory repo is the
# default when this is unset).
# DATABASE_URL=postgres://user:password@localhost:5432/branch
